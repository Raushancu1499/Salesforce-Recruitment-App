<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>MINPAY_LESS_THAN_MAX_PAY</fullName>
    <active>true</active>
    <errorConditionFormula>Min_Pay__c &gt;= Max_Pay__c</errorConditionFormula>
    <errorDisplayField>Max_Pay__c</errorDisplayField>
    <errorMessage>Min Pay must be less than Max Pay</errorMessage>
</ValidationRule>
