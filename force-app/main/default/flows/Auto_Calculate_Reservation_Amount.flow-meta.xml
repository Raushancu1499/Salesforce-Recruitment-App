<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <assignments>
        <name>Set_Total_Amount</name>
        <label>Set Total Amount</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Total_Amount__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Calculate_Total_Amount</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <environments>Default</environments>
    <formulas>
        <name>Calculate_Total_Amount</name>
        <dataType>Currency</dataType>
        <expression>( $Record.Check_Out_Date__c - $Record.Check_In_Date__c )
*
$Record.Room__r.Price_per_Night__c</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>Auto Calculate Reservation Amount {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Auto Calculate Reservation Amount</label>
